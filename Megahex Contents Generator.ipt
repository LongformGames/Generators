Megahex Contents Generator.ipt

;Generates megahex contents, per prompted megahex
; created 11/4/2025 11:12:26 AM
MaxReps=1
Prompt: {Border|Wild|Wilderness} Border
Prompt: {Forest|Hills|Mountain|Swamp} Forest
Prompt: Megahex Number {MH1|MH2|MH3|MH4|MH4a|MH5|MH6|MH7|MH7b|MH8|MH9|MH10|MH11|MH11a|MH12|MH13|MH14|MH14b|MH15|MH16|MH17|MH18|MH18a|MH19|MH20|MH21|MH21b} MH1
set: BorderSmallKingdomSite= {2d2}
set: BorderMediumKingdomSite={3d3}
set: BorderLargeKingdomSite={3d3+3}
set: WildSmallKingdomSite={1d2+1}
set: WildMediumKingdomSite={1d4+1}
set: WildLargeKingdomSite={1d4+2}
set: WildernessSmallKingdomSite={1d2+1}
set: WildernessMediumKingdomSite={1d3+1}
set: WildernessLargeKingdomSite={1d4+1}
set: LostCastleSite={1d3+1}
set: SmallTombComplex={1d2+1}
set: MediumTombComplex={1d8+2}
set: LargeTombComplex={1d10+10}
set: WildEery={1d3+1}
set: ContiguousWildEery={1d5+1}
set: ScatteredSettlements={1d2+1}
set: AverageSettlements={1d3+1}
set: DenseSettlements={1d4+2}
set: SettlementSize={70d4}
set: ScatteredSettlementsPop={{ScatteredSettlements}*{SettlementSize}}
set: AverageSettlements={1d3+1}
set: AverageSettlementsPop={{AverageSettlements}*{SettlementSize}}
set: DenseSettlements={1d4+2}
set: DenseSettlementsPop={{DenseSettlements}*{SettlementSize}}
set: DwarfBaseGroup={40d10}
set: DwarfVillagePop={{1d3+1}*250}
set: ElfVillagePop={({20d10}+25)*{1d6+6}}
set: ElfVillageLocations={1d3+1}
set: ElfHoldingLocations={1d2+1}
Set: WildElfHoldingLocations={1d3+1}
Set: ElfBand={20d10}
Set: AugmentedElfBand={{20d10}+50}
set: GoblinVillagePop={{120d10}+25*{1d3+1}}
Set: GoblinBaseGroup={40d10}
Set:GoblinBaseGroupWargs={{GoblinBaseGroup}/4}
set:MultiGoblinBandLocations={1d2+1}
set: MultiGoblinBands={{1d2+1}*{MultiGoblinBandLocations}}
set: MultiGoblinBandsWargs={{MultiGoblinBands}/4}
set: GoblinHoldingPop={{1d2+1}*{40d10}}
set: GoblinHoldingLocations={1d3}
set: GoblinWargBasePop={{GoblinVillagePop}/4}
set: GoblinWargHolding={{GoblinHoldingPop}/4}
set: OrcVillagePop={{120d10}}
set: OrcBaseGroup={30d10}
set: BorderOrcBandNumber={1d3}
set: WildOrcBandNumber={1d3+2}
set: WildernessOrcBandNumber={1d4+2}
set: BorderMountainOrcBandNumber={{1d3}+1}
set: WildMountainOrcBandNumber={{1d3}+3}
set: WildernessMountainOrcBandNumber={{1d4}+3}
set: BugbearBand={{5d4}*5}
set: WildBugbearPop={1d5}
Set: WildGiantkinPop={1d6}
//redo lost castle/lost city to better reflect map size
//should be one 6mi, mostly: change density of ruins, not expanse

Table: Results
<b>{$prompt3}</b> is a {$prompt1} {$prompt2} hex. \n Survivability: [@Survivability] \n[@{$prompt1}{$prompt2}SpecialHexType] &
<b>Denizens</b>: [@{$prompt1}{$prompt2}DenizenRouting]

//put common/general tables FIRST, as below
//faction leaders vary by type of faction; power levels, etc. not supported 1.0

Table: Survivability
Type: Lookup
Roll: 1d100
01-05: Poor (forage)
06-08: Poor (water)
09-10: Poor (forage and water)
11-85: Average
86-91: Good (forage)
92-96: Good (water)
97-100: Good (forage and water)

Table: AnomalousLocalPhenomenon
Type: Lookup
Roll: 1d100
01-50: roaming encounter
51-55: healing or rest
56-60: slow healing or bad rest
61-65: weather
66-71: blessing
72-77: curse
78-85: action for boon
86-87: oracle
88: mental bonus (insight, direction, spells) 
89: mental malus (confusion, direction, spells)
90: disease
91: madness
92: trade or bargain
93: sacrifice for boon
94: temporal distortion
95: transforming phenomenon
96: teleporting phenomenon
97: stasis/imprisoning phenomenon
98: power-granting phenomenon
99: extraplanar presence
100: deity presence

Table: AnomalousGlobalPhenomenon
Type: Lookup
Roll: 1d100
01-50: roaming encounter
51-58: healing or rest
59-65: slow healing or bad rest
66-72:  weather
73-79: blessing/bonus
80-85:  curse/malus
86-88: mental bonus (insight, direction, spells) 
89-91: mental malus (confusion, direction, spells)
92-94: power-granting phenomenon
95-96: temporal distortion
97: disease
98: madness
99: roaming deity presence
100: roaming extraplanar presence

