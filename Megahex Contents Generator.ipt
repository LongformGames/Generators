Table: DwarfHero
Type:Lookup
Roll: 1d100
01-72: a [Human|Dwarven|Dwarven|Dwarven|Dwarven|Dwarven] Fighter
73-77: a Human Fighter (werebear)
78-81: a Human Knight
81-100: a Human Ranger

Table: ElfLeader
Type: Lookup
Roll: 1d12
//2.0: elf leaders have magic item(s) at lvl*5%
set: ElvenFighterLevel={1d6+1}
set: ElvenMagicUserLevel={1d6+1}
set: ElvenKnightLevel={1d6+1}
//see knights.ipt in main nbos program file for the data structure I used for their magic
1-2: Leader: a level {ElvenFighterLevel} Elven Fighter \n
3-4: Leader: a level {ElvenMagicUserLevel} Elven Magic-User \n
5: Leader: a level {ElvenKnightLevel} Elven Knight \n
6-12: Leader: a level {ElvenFighterLevel} Fighter/level {ElvenMagicUserLevel} Magic-User \n

Table: ElfHero
Type:Lookup
Roll: 1d100
01: [|a Human|an Elven] Fighter 
02: [|a Human|an Elven] Knight 
03-67: an Elven Fighter/Magic-User
68-77: \a [|Human|Elven|Elven|Elven|] Magic-User 
78: a Human Cleric 
79-89: a Human Druid
90-100: \a [|Human|Human|Human|Elven] Ranger 

Table:GoblinHero
Type:Lookup
Roll: 1d100
01-04: A Human Cleric
05-69: [|a Human|a Human|a Half-Orc] Fighter
70-89: a Human Magic-User
90-100: a Human Thief

Table: OrcHero
Type:Lookup
Roll: 1d100
//note: half-orcs are humans beginning to be corrupted by orcneas
01-10:  a Half-Orc Assassin
11-12:  a Human Cleric
13-77: [|a Human|a Human|a Half-Orc|a Half-Orc] Fighter
78-79: a Human Knight
80-100: a Human Magic-User

