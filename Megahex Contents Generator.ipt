&nbsp; {ElfVillagePop} elves at \n &
&nbsp; [!{ElfVillageLocations} $prompt3}Base]  \n
 
Table:BorderForestSpecialHexType
Type: Lookup
Roll: 1d100
01-65: \z 
66-95: [@BorderForestRuins]
96-98: Megadungeon at <b>[@{$prompt3}Base]</b> \n
99-100:[@BorderForestAnomalous]

Table:BorderForestRuins
Type: Lookup
Roll: 1d100
01-53: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Lost Kingdom with {BorderSmallKingdomSite} sites \n 
54-60: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Lost Kingdom with {BorderMediumKingdomSite} sites \n &
61-64: <b>[@{$prompt3}Base]</b> <b>Ruins</b>:Lost Kingdom with {BorderLargeKingdomSite} sites \n &
65-75: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Lost City with a large central location at  <b> [@{$prompt3}Base]</b> \n 
76-79: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Lost Castle with {1d4} contiguous small-hex locations starting at &
<b> [@{$prompt3}Base]</b> \n 
80:<b>[@{$prompt3}Base]</b> <b>Ruins</b>: Small Tomb Complex with a tomb \n 
81-85: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Small Tomb Complex with {SmallTombComplex} tombs \n 
86-89: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Medium Tomb Complex with {MediumTombComplex} tombs \n 
90-91: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Large Tomb Complex with {LargeTombComplex} tombs \n 
92-95: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Mass Burial Site \n
96-99: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Battlefield </b>  \n
100: <b>[@{$prompt3}Base]</b> <b>Ruins</b>: Megatomb   \n 
	
Table: BorderForestAnomalous
Type: Lookup
Roll: 1d100
01-15: Single Eery hex \n
16-20: {WildEery} hexes \n &
Locations: [!{WildEery} {$prompt3}Base]\n
21-25: {WildEery} contiguous Eery Hexes  \n &
Start Location: <b>[@{$prompt3}Base]</b> \n
26-28: All forested hexes are Eery \n
29: Entire megahex is Eery \n
30-37: Anomalous [|localized|localized|localized|placebound] [@AnomalousLocalPhenomenon] \n &
Location: <b>[@{$prompt3}Base]</b> \n
38-40: Anomalous global [@AnomalousGlobalPhenomenon] \n
41-75: Anomalous structure at <b>[@{$prompt3}Base]</b> \n
76-100: Anomalous terrain feature at <b>[@{$prompt3}Base]</b> \n 
	
