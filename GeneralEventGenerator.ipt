; AnnualEventGenerator.ipt
; created 4/10/2026 12:20:40 PM
;NOTE format Roll: {{1d3}+10} will work for lookup; double vars doesn't
;table measures intensity of event PCs hear about
;table assumes most events happen where PCs aren't: it's a big world
;table assumes remote events that PCs hear about will be noteworthy 
;local distance may occasionally be area, v rarely distant; visitors always local, for instance
;every job object needs patron, distance (custom?), pay (custom?), twist check (custom?), notification date,
;job due date UP TO GM, except for winter jobs; extrapolate/negotiate for other seasons
set: LongMonthDay = {1d31}
set: ShortMonthDay = {1d30}
set: FebDay = {1d28}
use: common\OSEAdvancedTreasure.ipt
Prompt: Thaarn Year/RL Year {405/2025|406/2026|407/2027|408/2028|409/2029|430|2030} 405/2025

Table:Results
 <b>Year {$prompt1}</b> \n &nbsp; &nbsp; &nbsp; Year of the [@YearSymbol] \n \n &
<b>Global Events</b> \n \n &nbsp; [@GlobalEventDetails] \n  &
<b>Events by Month</b> \n &
\n <b>January</b> &nbsp; [RightDay=={1d31}] <b> [@WinterMonthlyCheck]</b>  &
\n &nbsp; &nbsp; <b>January Hometown Events</b>: [@WinterHometownCheck] &
\n <b>February</b> [RightDay=={1d28}] &
<b>[@WinterMonthlyCheck]</b> &
\n &nbsp; &nbsp; <b>February Hometown Events</b>: [@WinterHometownCheck] &
\n <b>March</b> [RightDay=={1d31}] &
\n <b>[@SpringMonthlyCheck]</b>  &
\n &nbsp; &nbsp; <b>March Hometown Events</b>: [@SpringHometownCheck] &
\n <b>April</b> <b>[RightDay=={1d30}]</b> &
<b>[@SpringMonthlyCheck]</b> &
\n &nbsp; &nbsp; <b>April Hometown Events</b>: [@SpringHometownCheck] &
\n <b>May</b> [RightDay=={1d31}] &
\n <b>[@SpringMonthlyCheck]</b> &
\n &nbsp; &nbsp; <b>May Hometown Events</b>: [@SpringHometownCheck] &
\n <b>June</b> [RightDay=={1d30}]  &
\n <b>[@JuneMonthlyCheck]</b> \n &
\n &nbsp; <b>[@SummerMonthlyCheck]</b>  &
\n &nbsp; &nbsp; <b>June Hometown Events</b>: [@SummerHometownCheck] &
\n <b>July</b> [RightDay=={1d31}] &
\n <b>[@SummerMonthlyCheck]</b>  &
\n &nbsp; &nbsp; <b>July Hometown Events</b>: [@SummerHometownCheck] &
\n <b>August</b> [RightDay=={1d31}] &
\n <b>[@SummerMonthlyCheck]</b> &
\n &nbsp; &nbsp; <b>August Hometown Events</b>: [@SummerHometownCheck] &
\n<b>September</b>  [RightDay=={1d30}] &
\n <b>[@FallMonthlyCheck]</b> &
\n &nbsp; &nbsp; <b>September Hometown Events</b>: [@FallHometownCheck] &
\n <b>October</b> \n <b>[@FallMonthlyCheck]</b> \n &
\n &nbsp; &nbsp; [@OctoberMonthlyEvents] &
\n &nbsp; &nbsp; <b>October Hometown Events</b>: \n [@FallHometownCheck] &
\n <b>November</b>  [RightDay=={1d31}] &
\n <b>[@FallMonthlyCheck]</b> &
\n &nbsp; &nbsp; <b>November Hometown Events</b>: [@FallHometownCheck] &
\n <b>December</b> &
\n &nbsp; &nbsp; [@DecemberMonthlyEvents] &
\n &nbsp; &nbsp; <b>December Hometown Events</b>: [@WinterHometownCheck]

Table:WinterHometownCheck
Type: Lookup
Roll: 1d100
01-30: None \n
31-65: \n [@WinterHometownEvents] 
66-85: \n [@2 WinterHometownEvents] 
86-100: \n [@3 WinterHometownEvents]

Table:SpringHometownCheck
Type: Lookup
Roll: 1d100
01-20: None \n 
21-100: \n [@3 SpringHometownEvents]
 
Table:SummerHometownCheck
Type: Lookup
Roll: 1d100
01-15: None \n 
16-100: \n [@5 SummerHometownEvents] 

Table:FallHometownCheck
Type: Lookup
Roll: 1d100
01-15: None 
16-100: [@4 FallHometownEvents]

Table:WinterHometownEvents
Type: Lookup
Roll: 1d100
; add News, Rumor, Visitor back in, that order after Job; % are correct
01-04: \n &nbsp; <b>Day {1d28}</b>: [@WinterJob] \n
05-44: \n &nbsp;<b>Day {1d28}</b>: [@WinterNews] \n
45-90: \n &nbsp; <b>Day {1d28}</b>: [@Rumor] \n
91-100: \n &nbsp; <b>Day {1d28}</b>: [@WinterVisitorType] \n

Table:SpringHometownEvents
Type: Lookup
Roll: 1d100
; add News, Rumor, Visitor back in, that order after Job % are correct
;news and visitor somewhat more common; news older
01-10: \n &nbsp; <b>Day {1d30}</b>: \n [@SpringJob] \n
11-70: \n &nbsp;<b>Day {1d30}</b>: \n [@SpringNews] \n
71-80: \n &nbsp; <b>Day {1d30}</b>: \n [@Rumor] \n
81-100: \n &nbsp; <b>Day {1d30}</b>: \n [@SpringVisitorType]

Table:SummerHometownEvents
Type: Lookup
Roll: 1d100
; add News, Rumor, Visitor back in, that order after Job % are correct
;news and visitor somewhat more common; news fresher
;jobs *should* be rarer, but it's a design decision, more b/c PCs most active
01-14: \n &nbsp;  <b>Day {1d30}</b> \n  [@SummerJob] \n
15-60: \n &nbsp; <b>Day {1d30}</b> \n [@SummerNews] \n
61-80: \n &nbsp; <b>Day {1d30}</b> \n [@Rumor] \n
81-100: \n &nbsp; <b>Day {1d30}</b> \n [@SummerVisitorType] 

Table:FallHometownEvents
Type: Lookup
Roll: 1d100
; add News, Rumor, Visitor back in, that order after Job % are correct
;news normal, rumor and visitor much more common (rumor from visitors)
01-06: \n &nbsp;; <b>Day {1d30}</b> \n [@FallJob] \n
07-42: \n &nbsp; <b>Day {1d30}</b> \n [@FallNews] \n
43-75: \n &nbsp; <b>Day {1d30}</b> \n [@Rumor] \n
76-100: \n &nbsp; <b>Day {1d30}</b> \n [@FallVisitorType] \n

Table: WinterNews
Type: Lookup
set: NewsRoll={{1d12}+2}
\n <b>News</b>: [#{NewsRoll} NewsDistance] [@NewsTopic] \n <b>Date</b>: [#{NewsRoll}  NewsDate] &
 \n <b>News Source</b>: [@NewsNotification] \n  <b>Veracity</b>: [#{NewsRoll} NewsVeracity][@ConnectionFlag] 

Table:SpringNews
Type: Lookup
set: NewsRoll={{1d10}+2}
1: \n <b>News</b>: [#{NewsRoll} NewsDistance] [@NewsTopic] \n <b>Date</b>: [#{NewsRoll} NewsDate] &
 \n <b>News Source</b>: [@NewsNotification] \n <b>Veracity</b>: [#{NewsRoll} NewsVeracity][@ConnectionFlag]  

Table:SummerNews
Type:Lookup
set: NewsRoll={1d10}
1: \n <b>News</b>: [#{NewsRoll} NewsDistance] [@NewsTopic] \n <b>Date</b>: [#{NewsRoll} NewsDate] &
 \n <b>News Source</b>: [@NewsNotification] \n <b>Veracity</b>:[#{NewsRoll} NewsVeracity] [@ConnectionFlag] 

Table:FallNews
Type: Lookup
set: NewsRoll={1d12}
1: \n <b>News</b>: [#{NewsRoll} NewsDistance] [@NewsTopic] \n <b>Date</b>: [#{NewsRoll} NewsDate] &
\n <b>News Source</b>: [@NewsNotification] \n <b>Veracity</b>: [#{NewsRoll} NewsVeracity] [@ConnectionFlag] 

Table: NewsTopic
Type:Lookup
Roll: 1d100
01-24: [@NewsClash] 
25-49: [@NewsDiscovery]
50-74: [@NewsDenizen]   
75-100: [@NewsPolitical] 

Table:NewsClash
Type:Lookup
Roll: 1d10
1-5: [@MonthlyClash] \n
6-7: Feud between [|individual|faction] and [|individual|faction]
8: Plunder of settlement by [|monsters|adventurers|human group|humanoids|demihumans|unknown forces] \n
9: Plunder of humanoid settlement \n
10: Plunder of adventure location \n

Table: NewsDiscovery
1-3: <b> Location Discovery</b>: [@AdventureLocationDiscovery]
4: <b>Anomaly discovery</b>:
5-7: <b>Crime discovery</b>:
8: <b>Faction action discovery</b>:
9: <b>Hoard discovery</b>:
10: <b>Item or object discovery</b>:
11-14: <b>Lair discovery</b>:
15-17: <b>Beast or monster signs discovery</b>:
18-20: <b>Scandal/secret about [|faction|political|criminal|civic|military|prominent|religious] figure

Table: AdventureLocationDiscovery
Type: Lookup
Roll: 1d12
1-4: Lair
5-6: Monster cluster
7: Lair: [@NewsHero]
8: Apex lair
9-10: Ruin
11: Dungeon
12: Anomaly

